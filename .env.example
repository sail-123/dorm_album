# ===== Google Sheets =====
# サービスアカウントのJSONをそのまま文字列で入力（改行なし）
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"YOUR_PROJECT","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"YOUR@PROJECT.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# または credentials.json ファイルを置く場合（ローカル開発用）
# GOOGLE_CREDENTIALS_FILE=credentials.json

# スプレッドシートのID（URLの /d/〇〇〇/edit の〇〇〇部分）
SPREADSHEET_ID=your_spreadsheet_id_here

# ===== Cloudinary =====
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===== Google Sheets シート構成 =====
# 以下のシートを作成し、1行目にヘッダーを入力してください
#
# [members]
#   id, name, room, phone, email, role, join_date, password
#   ※ role: admin または member
#   ※ password: SHA-256ハッシュ値
#
# [cleaning_tasks]
#   id, member_id, location, start_date, end_date, status
#   ※ status: pending または done
#
# [payments]
#   id, title, amount, due_date, description
#
# [payment_status]
#   id, payment_id, member_id, paid
#   ※ paid: true または false
#
# [items]
#   id, name, quantity, location, status
#
# [albums]
#   id, title, description, image_url, author_id, created_at, likes
#   ※ likes: JSON配列文字列 例: ["id1","id2"]
#
# [album_comments]
#   id, album_id, author_id, content, created_at
#
# [announcements]
#   id, title, content, author_id, created_at
#
# [boards]
#   id, title, content, author_id, created_at
#
# [comments]
#   id, board_id, author_id, content, created_at
#
# [rules]
#   id, title, content, updated_at
